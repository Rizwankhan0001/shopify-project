{% if request.page_type == 'index' %}
<section class="homepage-categories-peak">
  <div class="page-width">

    {% if section.settings.heading != blank %}
      <h2 class="peak-categories-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="peak-categories-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="peak-categories-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="peak-category-card" {{ block.shopify_attributes }}>

          {% if block.settings.image != blank %}
            <div class="peak-category-image">
              <img
                src="{{ block.settings.image | img_url: '300x300' }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            </div>
          {% endif %}

          <span class="peak-category-title">
            {{ block.settings.title }}
          </span>

        </a>
      {% endfor %}
    </div>

  </div>
</section>
{% endif %}

<style>
/* =====================================
   PEAK THEME – HOMEPAGE CATEGORIES
===================================== */

.homepage-categories-peak {
  padding: 60px 20px;
  background: #910A34; /* soft pink background */
}

/* Heading */
.peak-categories-heading {
  text-align: center;
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 8px;
  color:White;
}

/* Subheading */
.peak-categories-subheading {
  text-align: center;
  font-size: 16px;
  margin-bottom: 40px;
  color: #555; /* darker for contrast on pink */
}

/* Grid */
.peak-categories-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 30px;
  justify-items: center;
}

/* Card */
.peak-category-card {
  text-decoration: none !important;
  text-align: center;
  background: #ffffff;
  padding: 20px 15px;
  border-radius: 16px;
  width: 100%;
  max-width: 190px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

/* FORCE VISIBILITY (Peak fix) */
.peak-category-card,
.peak-category-card * {
  opacity: 1 !important;
  visibility: visible !important;
}

/* Hover */
.peak-category-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 14px 30px rgba(0,0,0,0.1);
}

/* Image */
.peak-category-image {
  display: flex;
  justify-content: center;
  margin-bottom: 10px;
}

.peak-category-image img {
  width: 110px;
  height: 110px;
  border-radius: 50%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.peak-category-card:hover img {
  transform: scale(1.1);
}

/* Title */
.peak-category-title {
  display: block !important;
  font-size: 16px !important;
  font-weight: 600 !important;
  line-height: 1.3;
  margin-top: 6px;
  color: #414142 !important;
  text-align: center;
}

/* Title hover */
.peak-category-card:hover .peak-category-title {
  color: #EF477D !important; /* pink hover */
}

/* =========================
   RESPONSIVE
========================= */

/* Tablet */
@media (max-width: 1024px) {
  .peak-categories-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* Mobile – Horizontal Scroll */
@media (max-width: 768px) {
  .peak-categories-grid {
    display: flex; /* switch grid to flex */
    overflow-x: auto; /* enable horizontal scroll */
    gap: 15px;
    padding-bottom: 10px;
  }

  .peak-category-card {
    flex: 0 0 45%; /* show ~2 cards in viewport */
    max-width: 45%;
  }

  .peak-category-image img {
    width: 85px;
    height: 85px;
  }

  .peak-category-title {
    font-size: 14px !important;
  }

  /* Hide scrollbar for cleaner look */
  .peak-categories-grid::-webkit-scrollbar {
    display: none;
  }
  .peak-categories-grid {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
}
</style>

{% schema %}
{
  "name": "Homepage Categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore our collections"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Category Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homepage Categories",
      "category": "Homepage"
    }
  ]
}
{% endschema %}
