<div class="df-promo-strip-wrapper">

<style>
.df-promo-strip-wrapper{
margin:20px 0;
}

.df-promo-strip{
display:block;
text-decoration:none;
border-radius:12px;
padding:16px 20px;
text-align:center;
font-weight:600;
font-size:16px;
transition:all 0.25s ease;
background:linear-gradient(135deg,#ffe0ec,#fff4b5);
color:#7a0033;
border:1px solid rgba(0,0,0,0.05);
box-shadow:0 4px 14px rgba(0,0,0,0.06);
}

.df-promo-strip span{
font-weight:500;
margin-left:6px;
font-size:14px;
opacity:0.85;
}

.df-promo-strip:hover{
transform:translateY(-2px);
box-shadow:0 8px 20px rgba(0,0,0,0.12);
}
</style>

<a href="{{ section.settings.link }}" class="df-promo-strip">

✨ {{ section.settings.text }}

<span>→ Explore</span>

</a>

</div>


{% schema %}
{
  "name": "Promo Strip",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Strip Text",
      "default": "Explore Value Combos – More Variety, Better Savings"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Promo Strip"
    }
  ]
}
{% endschema %}